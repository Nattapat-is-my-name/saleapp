# Server
HOST=0.0.0.0
PORT=8080
ENV=development

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=saleapp
DB_USER=postgres
DB_PASSWORD=postgres
DB_SSL_MODE=disable

# JWT
JWT_SECRET=your-secret-key-min-32-chars-here
JWT_EXPIRY_HOURS=24

# Stripe
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_signing_secret

# Optional
LOG_LEVEL=debug
